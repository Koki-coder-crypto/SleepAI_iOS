default_platform(:ios)
platform :ios do
  lane :submit do
    setup_ci if ENV["CI"]
    api_key = app_store_connect_api_key(key_id: ENV["ASC_KEY_ID"], issuer_id: ENV["ASC_ISSUER_ID"], key_content: ENV["ASC_PRIVATE_KEY"], is_key_content_base64: false)
    sh("xcodegen generate --spec ../project.yml")
    build_app(scheme: "SleepAI", project: "SleepAI.xcodeproj", configuration: "Release", output_directory: "./build", output_name: "SleepAI.ipa", export_method: "app-store", xcargs: "DEVELOPMENT_TEAM=#{ENV["DEVELOPMENT_TEAM"]} ANTHROPIC_API_KEY=#{ENV["ANTHROPIC_API_KEY"]}", clean: true)
    upload_to_testflight(api_key: api_key, ipa: "./build/SleepAI.ipa", skip_waiting_for_build_processing: false, distribute_external: false)
    deliver(api_key: api_key, ipa: "./build/SleepAI.ipa", app_identifier: "com.kokicoder.sleepai", name: "SleepAI - Sleep Coach & Tracker",
      description: { "en-US" => File.read("app_store/description_en.txt"), "ja" => File.read("app_store/description_ja.txt") },
      keywords: { "en-US" => "sleep tracker,sleep coach,ai sleep,sleep analysis,sleep quality,insomnia,better sleep,sleep improvement", "ja" => "睡眠トラッカー,睡眠コーチ,AI睡眠,睡眠分析,睡眠品質,不眠症,快眠,睡眠改善" },
      release_notes: { "en-US" => File.read("app_store/whats_new_en.txt"), "ja" => File.read("app_store/whats_new_ja.txt") },
      primary_category: "HEALTH_AND_FITNESS", secondary_category: "UTILITIES",
      privacy_url: "https://github.com/Koki-coder-crypto/LynQ_backend/blob/master/app_store/privacy_policy.html",
      support_url: "https://github.com/Koki-coder-crypto/LynQ_backend/issues", price_tier: 0,
      submission_information: { export_compliance_uses_encryption: false, export_compliance_is_exempt: true, add_id_info_uses_idfa: false, add_id_info_serves_ads: false, add_id_info_tracks_action: false, add_id_info_tracks_install: false, add_id_info_limits_tracking: true, content_rights_has_rights: true, content_rights_contains_third_party_content: false },
      submit_for_review: true, automatic_release: false, skip_screenshots: true, skip_metadata: false, force: true)
    UI.success("SleepAI submitted!")
  end
  lane :build_only do
    sh("xcodegen generate --spec ../project.yml")
    build_app(scheme: "SleepAI", project: "SleepAI.xcodeproj", configuration: "Release", output_directory: "./build", output_name: "SleepAI.ipa", export_method: "app-store", xcargs: "DEVELOPMENT_TEAM=#{ENV["DEVELOPMENT_TEAM"]} ANTHROPIC_API_KEY=#{ENV["ANTHROPIC_API_KEY"]}", clean: true)
  end
end
